--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Customer_pt
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: pt
  m_SharedData: {fileID: 11400000, guid: a7ba446bad0fa4742a59ed3872cfeb37, type: 2}
  m_Metadata:
    m_Items:
    - rid: 3351683259623538690
  m_TableData:
  - m_Id: 28479095619584
    m_Localized: "Uau, que caro!\nO {productName} costuma custar esse pre\xE7o?"
    m_Metadata:
      m_Items:
      - rid: 3351683259623538690
  - m_Id: 28479829622784
    m_Localized: "Este {productName} est\xE1 um pouco fora do meu or\xE7amento."
    m_Metadata:
      m_Items:
      - rid: 3351683259623538690
  - m_Id: 28480471351296
    m_Localized: "Tem certeza de que esse \xE9 o pre\xE7o correto para o {productName}?"
    m_Metadata:
      m_Items:
      - rid: 3351683259623538690
  - m_Id: 28481104691200
    m_Localized: "\xC9 muito caro para um {productName}."
    m_Metadata:
      m_Items:
      - rid: 3351683259623538690
  - m_Id: 28481809334272
    m_Localized: "Tem alguma promo\xE7\xE3o no {productName}\nou uma alternativa
      mais barata?"
    m_Metadata:
      m_Items:
      - rid: 3351683259623538690
  - m_Id: 28483789045760
    m_Localized: "Vou ter que pensar sobre isso.\nO {productName} \xE9 um pouco caro."
    m_Metadata:
      m_Items:
      - rid: 3351683259623538690
  - m_Id: 28486444040192
    m_Localized: "Ai! Minha carteira est\xE1 chorando.\nVou ter que deixar o {productName}
      para depois."
    m_Metadata:
      m_Items:
      - rid: 3351683259623538690
  - m_Id: 145255088128
    m_Localized: Tudo bem, tudo bem... eu vou pagar.
    m_Metadata:
      m_Items: []
  - m_Id: 18485176483840
    m_Localized: Ei, calma! Eu vou devolver.
    m_Metadata:
      m_Items: []
  - m_Id: 22180433805312
    m_Localized: "Voc\xEA me pegou... eu vou pagar por isso."
    m_Metadata:
      m_Items: []
  - m_Id: 22192815390720
    m_Localized: "N\xE3o precisa bater! Foi um erro..."
    m_Metadata:
      m_Items: []
  - m_Id: 22207277350912
    m_Localized: "Por favor, n\xE3o chame a pol\xEDcia. Vou pagar agora."
    m_Metadata:
      m_Items: []
  - m_Id: 22222410399744
    m_Localized: "Voc\xEA venceu. Eu vou pagar, eu juro!"
    m_Metadata:
      m_Items: []
  - m_Id: 22234892648448
    m_Localized: "Por favor, n\xE3o conte a ningu\xE9m. Vou pagar agora."
    m_Metadata:
      m_Items: []
  - m_Id: 22251669864448
    m_Localized: Tudo bem, tudo bem, relaxa... vou devolver tudo.
    m_Metadata:
      m_Items: []
  - m_Id: 22263413915648
    m_Localized: Sem problemas aqui. Vou devolver.
    m_Metadata:
      m_Items: []
  - m_Id: 22277678743552
    m_Localized: Calma, cara! Eu vou pagar por isso.
    m_Metadata:
      m_Items: []
  - m_Id: 25994494787584
    m_Localized: "Ugh, n\xE3o consigo encontrar nada em lugar nenhum."
    m_Metadata:
      m_Items: []
  - m_Id: 26010269564928
    m_Localized: "Onde est\xE1? Procurei em todos os lugares..."
    m_Metadata:
      m_Items: []
  - m_Id: 26064367697920
    m_Localized: Era para eles terem isso aqui...
    m_Metadata:
      m_Items: []
  - m_Id: 26071183441920
    m_Localized: "Esta loja est\xE1 uma bagun\xE7a.\nComo vou encontrar alguma coisa?"
    m_Metadata:
      m_Items: []
  - m_Id: 26073293176832
    m_Localized: "S\xE9rio? Nada?"
    m_Metadata:
      m_Items: []
  - m_Id: 26074366918656
    m_Localized: 'Estou perdendo meu tempo.

      Melhor eu ir para outro lugar.'
    m_Metadata:
      m_Items: []
  - m_Id: 26075272888320
    m_Localized: "Talvez eu devesse perguntar a algu\xE9m...\nmas odeio pedir ajuda."
    m_Metadata:
      m_Items: []
  - m_Id: 26077726556160
    m_Localized: "Provavelmente eles nem t\xEAm em estoque."
    m_Metadata:
      m_Items: []
  - m_Id: 26079135842304
    m_Localized: Nunca mais volto a esta loja.
    m_Metadata:
      m_Items: []
  - m_Id: 26080410910720
    m_Localized: "N\xE3o acredito que n\xE3o consigo encontrar o que estou procurando."
    m_Metadata:
      m_Items: []
  - m_Id: 28482484617216
    m_Localized: "N\xE3o tenho dinheiro para isso!"
    m_Metadata:
      m_Items: []
  - m_Id: 28483155705856
    m_Localized: "Isso \xE9 um roubo!"
    m_Metadata:
      m_Items: []
  - m_Id: 28484464328704
    m_Localized: "Produtos semelhantes que sejam mais acess\xEDveis?"
    m_Metadata:
      m_Items: []
