  m_TableData:
  - m_Id: 1209035440128
    m_Localized: Ein Kassierer arbeitet bereits hier.
    m_Metadata:
      m_Items: []
  - m_Id: 2573031489536
    m_Localized: Unzureichendes Wechselgeld. Bitte geben Sie den korrekten Betrag
      an.
    m_Metadata:
      m_Items: []
  - m_Id: 3124343390208
    m_Localized: "Ung\xFCltiger Betrag. Bitte geben Sie einen g\xFCltigen Betrag
      ein."
    m_Metadata:
      m_Items: []
  - m_Id: 83409761492992
    m_Localized: "Hier k\xF6nnen keine M\xF6bel aufgestellt werden!"
    m_Metadata:
      m_Items: []
  - m_Id: 91272345051136
    m_Localized: Hier kann kein Objekt geworfen werden!
    m_Metadata:
      m_Items: []
  - m_Id: 91565879222272
    m_Localized: Dieses Regal ist einem anderen Produkt zugeordnet.
    m_Metadata:
      m_Items: []
  - m_Id: 91838072774656
    m_Localized: "Das Produkt geh\xF6rt nicht in diesen Bereich."
    m_Metadata:
      m_Items: []
  - m_Id: 91979538259968
    m_Localized: "Das Regal enth\xE4lt ein anderes Produkt."
    m_Metadata:
      m_Items: []
  - m_Id: 661342849646592
    m_Localized: Das Regal ist voll!
    m_Metadata:
      m_Items: []
  - m_Id: 92224317841408
    m_Localized: Der Karton ist voll.
    m_Metadata:
      m_Items: []
  - m_Id: 92318307999744
    m_Localized: "Der Karton enth\xE4lt ein anderes Produkt."
    m_Metadata:
      m_Items: []
  - m_Id: 92423127851008
    m_Localized: "Inkompatible Kartongr\xF6\xDFe."
    m_Metadata:
      m_Items: []
  - m_Id: 92578585534464
    m_Localized: "Das Lagerregal enth\xE4lt ein anderes Produkt."
    m_Metadata:
      m_Items: []
  - m_Id: 683213758447616
    m_Localized: Das Lagerregal ist voll!
    m_Metadata:
      m_Items: []
  - m_Id: 457185107927040
    m_Localized: Level aufgestiegen!
    m_Metadata:
      m_Items: []
  - m_Id: 467368643158016
    m_Localized: '{0} erfolgreich eingestellt!'
    m_Metadata:
      m_Items: []
  - m_Id: 467478592643072
    m_Localized: '{0} entlassen!'
    m_Metadata:
      m_Items: []
  - m_Id: 467651964198912
    m_Localized: Schalten Sie zuerst das Lager frei!
    m_Metadata:
      m_Items: []
  - m_Id: 467988183801856
    m_Localized: "Keine Kasse f\xFCr diesen Kassierer verf\xFCgbar!"
    m_Metadata:
      m_Items: []
  - m_Id: 468400232226816
    m_Localized: "Kein freier Platz f\xFCr diesen {EmployeeType} verf\xFCgbar!"
    m_Metadata:
      m_Items: []
  - m_Id: 467813864333312
    m_Localized: Du hast nicht genug Geld!
    m_Metadata:
      m_Items: []
  - m_Id: 498326742261760
    m_Localized: Dieser Kredit ist bereits aktiv.
    m_Metadata:
      m_Items: []
  - m_Id: 652818342002688
    m_Localized: Belohnung eingesammelt!
    m_Metadata:
      m_Items: []
  - m_Id: 670737037836288
    m_Localized: Der Warenkorb ist leer!
    m_Metadata:
      m_Items: []
  - m_Id: 670795917475840
    m_Localized: Bezahlvorgang abgeschlossen!
    m_Metadata:
      m_Items: []
